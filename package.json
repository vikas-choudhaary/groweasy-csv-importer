{
  "name": "groweasy-csv-importer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "next dev --webpack",
    "dev:backend": "nodemon --watch server/src -e ts --exec \"ts-node --project server/tsconfig.json server/src/server.ts\"",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "next build",
    "build:backend": "tsc -p server/tsconfig.json",
    "build": "npm run build:frontend && npm run build:backend",
    "start:frontend": "next start",
    "start:backend": "node server/dist/server.js",
    "start": "next start",
    "test": "tsx --test tests/unit.test.ts tests/retry.test.ts tests/integration.test.ts tests/mapping.test.ts tests/regression.test.ts tests/duplicate.test.ts",
    "test:e2e": "tsx --test tests/e2e.test.ts",
    "lint": "eslint",
    "verify": "npm run lint && tsc --noEmit && tsc -p server/tsconfig.json --noEmit && npm test"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.12",
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.14.5",
    "ai": "^7.0.20",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "motion": "^12.42.2",
    "multer": "^2.2.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
